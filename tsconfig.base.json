{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@faro/domain": ["./packages/domain/src/index.ts"],
      "@faro/application": ["./packages/application/src/index.ts"],
      "@faro/infra-db": ["./packages/infra-db/src/index.ts"],
      "@faro/infra-ai": ["./packages/infra-ai/src/index.ts"],
      "@faro/observability": ["./packages/observability/src/index.ts"],
      "@faro/config": ["./packages/config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
