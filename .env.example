# Faro — variables de entorno (copiar a .env y completar). NUNCA commitear .env.
# La config se valida con Zod al boot (packages/config). Sin claves, los adapters
# de IA deben degradar con error claro (no romper el build, no silenciar).

# --- IA (Anthropic) ---
# IDs vigentes: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
# Consultar la skill `claude-api` antes de fijar precios/caching.
ANTHROPIC_API_KEY=

# --- Embeddings legales/curriculares (Voyage) ---
# Dimensión la fija corpus_version (voyage-law-2). [VERIFICAR] dim exacta.
VOYAGE_API_KEY=

# --- Reranker (opcional: Cohere; alternativa = pase barato de Haiku) ---
COHERE_API_KEY=

# --- Base de datos (Postgres + pgvector) ---
DATABASE_URL=postgresql://faro:faro@localhost:5432/faro

# --- Entorno ---
NODE_ENV=development

# --- IA (Gemini / Google) ---
# Material para colorear (line-art generado): sin esta key el adapter degrada a placeholder.
GEMINI_API_KEY=
# Proveedor de imagen: "imagen" (Imagen 4 Fast, deprecado 2026-08-17) | "gemini" (Gemini Flash Image)
FARO_IMAGE_PROVIDER=imagen
